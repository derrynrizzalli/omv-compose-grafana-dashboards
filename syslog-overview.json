{
  "apiVersion": "dashboard.grafana.app/v2",
  "kind": "Dashboard",
  "metadata": {
    "name": "syslog-overview"
  },
  "spec": {
    "title": "Syslog Overview",
    "description": "Summary of homelab logs from Loki, surfacing anything that needs attention. Two sources with different label sets: job=syslog (omv, GL-MT5000, UniFi, shipped by Vector) drives the Host variable and the first rows; job=systemd-journal (Home Assistant, shipped by the Grafana Alloy add-on) drives its own row and is not affected by the Host variable. Windows Event Logs are not currently reaching Loki.",
    "tags": [
      "homelab",
      "syslog",
      "loki",
      "homeassistant"
    ],
    "editable": true,
    "liveNow": false,
    "preload": false,
    "cursorSync": "Off",
    "links": [],
    "annotations": [
      {
        "kind": "AnnotationQuery",
        "spec": {
          "builtIn": true,
          "enable": true,
          "hide": true,
          "iconColor": "rgba(0, 211, 255, 1)",
          "name": "Annotations & Alerts",
          "query": {
            "kind": "DataQuery",
            "group": "grafana",
            "version": "v0",
            "datasource": {
              "name": "-- Grafana --"
            },
            "spec": {}
          }
        }
      }
    ],
    "variables": [
      {
        "kind": "QueryVariable",
        "spec": {
          "name": "host",
          "label": "Host",
          "description": "Driven by label_values() so it tracks reality. The regex drops the timestamp-shaped hostnames produced by the UniFi syslog parse bug.",
          "hide": "dontHide",
          "skipUrlSync": false,
          "multi": true,
          "includeAll": true,
          "allValue": ".*",
          "allowCustomValue": true,
          "current": {
            "text": [
              "All"
            ],
            "value": [
              "$__all"
            ]
          },
          "options": [],
          "refresh": "onDashboardLoad",
          "regex": "",
          "sort": "alphabeticalAsc",
          "definition": "label_values({job=\"syslog\", host!~\"20[0-9]{2}-.*\"}, host)",
          "query": {
            "kind": "DataQuery",
            "group": "loki",
            "version": "v0",
            "datasource": {
              "name": "P8E80F9AEF21F6940"
            },
            "spec": {
              "refId": "LokiVariableQueryEditor-VariableQuery",
              "qryType": 1,
              "label": "host",
              "stream": "{job=\"syslog\", host!~\"20[0-9]{2}-.*\"}"
            }
          }
        }
      }
    ],
    "elements": {
      "panel-1": {
        "kind": "Panel",
        "spec": {
          "id": 1,
          "title": "Critical & Alert",
          "description": "emerg/alert/crit syslog lines in the selected time range. Anything above zero is worth a look.",
          "links": [],
          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "query": {
                      "kind": "DataQuery",
                      "group": "loki",
                      "version": "v0",
                      "datasource": {
                        "name": "P8E80F9AEF21F6940"
                      },
                      "spec": {
                        "expr": "sum(count_over_time({job=\"syslog\", host=~\"$host\", severity=~\"emerg|alert|crit\"}[$__range]))"
                      }
                    },
                    "refId": "A",
                    "hidden": false
                  }
                }
              ],
              "transformations": [],
              "queryOptions": {}
            }
          },
          "vizConfig": {
            "kind": "VizConfig",
            "group": "stat",
            "version": "",
            "spec": {
              "options": {
                "colorMode": "background",
                "graphMode": "area",
                "justifyMode": "auto",
                "orientation": "auto",
                "percentChangeColorMode": "standard",
                "reduceOptions": {
                  "calcs": [
                    "lastNotNull"
                  ],
                  "fields": "",
                  "values": false
                },
                "showPercentChange": false,
                "textMode": "auto",
                "wideLayout": true
              },
              "fieldConfig": {
                "defaults": {
                  "unit": "short",
                  "color": {
                    "mode": "thresholds"
                  },
                  "thresholds": {
                    "mode": "absolute",
                    "steps": [
                      {
                        "color": "green",
                        "value": 0
                      },
                      {
                        "color": "red",
                        "value": 1
                      }
                    ]
                  },
                  "mappings": [
                    {
                      "options": {
                        "match": "null",
                        "result": {
                          "text": "0"
                        }
                      },
                      "type": "special"
                    }
                  ]
                },
                "overrides": []
              }
            }
          }
        }
      },
