        "type": "query",
        "datasource": { "type": "influxdb", "uid": "${datasource}" },
        "definition": "schema.tagValues(bucket, tag: entity_id, measurement == µg/m³ and entity_id =~ /pm2/)",
        "query": "import \"influxdata/influxdb/schema\"\nschema.tagValues(bucket: \"${bucket}\", tag: \"entity_id\", predicate: (r) => r._measurement == \"µg/m³\" and r.entity_id =~ /pm2/, start: -30d)",
        "current": { "text": "All", "value": "$__all" },
        "options": [],
        "refresh": 2,
        "regex": "",
        "sort": 1,
        "multi": true,
        "includeAll": true,
        "hide": 0,
        "skipUrlSync": false
