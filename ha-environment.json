  "description": "Home Assistant environment sensors (temperature, humidity, air quality) from InfluxDB2, with conditional colour thresholds and cross-metric comparison.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "liveNow": false,
  "refresh": "5m",
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["home-assistant", "environment", "influxdb"],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "label": "InfluxDB source",
        "type": "datasource",
        "query": "influxdb",
        "current": {},
        "hide": 0,
        "refresh": 1,
        "regex": "",
        "skipUrlSync": false
      },
      {
        "name": "bucket",
        "label": "Bucket",
        "type": "textbox",
        "query": "homeassistant",
        "current": { "text": "homeassistant", "value": "homeassistant" },
        "options": [ { "text": "homeassistant", "value": "homeassistant", "selected": true } ],
        "hide": 0,
        "skipUrlSync": false
      },
      {
        "name": "temp_unit",
        "label": "Temp unit",
        "type": "custom",
        "query": "°C,°F",
        "current": { "text": "°C", "value": "°C" },
        "options": [
          { "text": "°C", "value": "°C", "selected": true },
          { "text": "°F", "value": "°F", "selected": false }
        ],
        "hide": 0,
        "multi": false,
        "includeAll": false,
        "skipUrlSync": false
      },
      {
        "name": "temp_sensors",
        "label": "Temperature sensors",
        "type": "query",
        "datasource": { "type": "influxdb", "uid": "${datasource}" },
        "definition": "schema.tagValues(bucket, tag: entity_id, measurement == temp_unit)",
        "query": "import \"influxdata/influxdb/schema\"\nschema.tagValues(bucket: \"${bucket}\", tag: \"entity_id\", predicate: (r) => r._measurement == \"${temp_unit}\", start: -30d)",
        "current": { "text": "All", "value": "$__all" },
        "options": [],
        "refresh": 2,
        "regex": "",
        "sort": 1,
        "multi": true,
        "includeAll": true,
        "hide": 0,
        "skipUrlSync": false
      },
      {
        "name": "humidity_sensors",
        "label": "Humidity sensors",
        "type": "query",
        "datasource": { "type": "influxdb", "uid": "${datasource}" },
        "definition": "schema.tagValues(bucket, tag: entity_id, measurement == % and entity_id =~ /humid/)",
        "query": "import \"influxdata/influxdb/schema\"\nschema.tagValues(bucket: \"${bucket}\", tag: \"entity_id\", predicate: (r) => r._measurement == \"%\" and r.entity_id =~ /humid/, start: -30d)",
        "current": { "text": "All", "value": "$__all" },
        "options": [],
        "refresh": 2,
        "regex": "",
        "sort": 1,
        "multi": true,
        "includeAll": true,
        "hide": 0,
        "skipUrlSync": false
      },
      {
        "name": "pm25_sensors",
